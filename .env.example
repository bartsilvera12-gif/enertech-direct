# Copiá este archivo a .env.local y completá con tu API Supabase (self-hosted).
# Reiniciá `npm run dev` después de cambiar variables.
#
# Build de producción (Hostinger / CI): .env.local NO viaja por git.
# Definí las mismas VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY en el panel del hosting
# (variables de entorno del build) antes de ejecutar `npm run build`; si no, el bundle no conectará a Supabase.

# URL base de la API (incluí https:// o solo el dominio; el código agrega https si falta).
# Debe ser el mismo proyecto Supabase / Kong que expone PostgREST sobre la base donde está el schema `enertech`
# (misma instancia que importás por SUPABASE_DB_URL en scripts DBA; si no coinciden, el catálogo no verá los datos).
VITE_SUPABASE_URL=https://tu-dominio.com

# Clave anónima (Dashboard / Settings / API)
VITE_SUPABASE_ANON_KEY=tu_anon_key

# ── PostgreSQL directo (solo scripts DBA / migraciones locales; no exponer al cliente Vite)
# Pooler Supavisor: usuario = postgres.<tenant-id>, no usar solo "postgres".
# Ejemplo de forma (reemplazar host, usuario tenant y contraseña):
# DIRECT_POSTGRES_URL=postgresql://postgres.TU_TENANT_ID:TU_PASSWORD@TU_HOST:5432/postgres

# Preferida para migraciones DDL (rol con permisos ALTER en enertech, p. ej. supabase_admin):
# SUPABASE_DB_URL=postgresql://supabase_admin:TU_PASSWORD@TU_HOST:5432/postgres

# ── Integración Fastrax (SOLO server-side: scripts/fastrax/*.mjs).
# NUNCA usar prefijo VITE_ (expondría credenciales al navegador). Cargar valores reales
# en .env.local (no versionado). Acá van solo placeholders.
FASTRAX_ENABLED=1
FASTRAX_API_URL=https://host-fastrax/MarketPlace/production.php
FASTRAX_COD=tu_codigo
FASTRAX_PASS=tu_password
# Tamaño/concurrencia para ope=2 batch en buscador admin / sync.
FASTRAX_DETAIL_BATCH_SIZE=20
FASTRAX_DETAIL_CONCURRENCY=2
# Página default para list-fast / search-global (ope=4).
FASTRAX_OPE4_DEFAULT_PAGE_SIZE=50
# Tope defensivo de imágenes locales bajadas por SKU (ope=3).
FASTRAX_IMAGE_MAX_PER_PRODUCT=10
# Grupo/agrupador para el PRIMER ítem en ope=12 (Tradexpar usa GRA distinto en single-line). Vacío = ok.
FASTRAX_GRA_FIRST=
# Fastrax suele exigir TLS sin cert autenticado; 1 desactiva la verificación SOLO server-side.
FASTRAX_SSL_INSECURE=1
FASTRAX_REQUEST_TIMEOUT_MS=90000
# Forma de pago de pedidos (ope=12): 3 = Otros.
FASTRAX_PGT=3
# Código de cliente registrado en Fastrax para autorizar la venta (ope=12, campo `cli`).
# Fastrax exige un cliente válido; sin esto responde "venda não autorizada" (errores 73/74).
# Suele ser el "consumidor final" de tu cuenta. Pedíle el código a tu proveedor Fastrax.
FASTRAX_CLI=
# 1 = facturar (ope=15) automáticamente tras enviar pedido. Dejar en 0 salvo decisión explícita.
FASTRAX_AUTO_INVOICE=0
# Cerrojo extra: 1 habilita el envío real de pedidos (ope=12). 0 = dry-run aunque se pase --confirm.
FASTRAX_CREATE_REMOTE_ORDERS=0

# ── Despacho automático de pedidos a Fastrax (server/fastrax-order-dispatcher.mjs).
# 1 = el server hace polling de pedidos nuevos con líneas Fastrax y los envía (ope=12) solo.
# Doble cerrojo: con FASTRAX_AUTO_DISPATCH=1 pero FASTRAX_CREATE_REMOTE_ORDERS=0 corre en DRY-RUN
# (detecta y loguea, no envía). Para envío real: ambos en 1.
FASTRAX_AUTO_DISPATCH=0
# Cada cuánto revisa pedidos pendientes (ms). Default 15000, mínimo 5000.
FASTRAX_AUTO_DISPATCH_INTERVAL_MS=15000
# Solo considera pedidos creados dentro de esta ventana (horas). Acota el scan. Default 72.
FASTRAX_AUTO_DISPATCH_LOOKBACK_HOURS=72
# Máximo de pedidos procesados por ciclo. Default 10.
FASTRAX_AUTO_DISPATCH_BATCH=10

# ── Mini-backend Fastrax (server/index.mjs): el admin dispara el sync desde el catálogo.
# Guarda las credenciales server-side; el navegador solo manda su JWT de Supabase.
# Para validar el JWT el backend reusa SUPABASE_URL/VITE_SUPABASE_URL y SUPABASE_ANON_KEY/VITE_SUPABASE_ANON_KEY.
# DEPLOY: corre en la VPS bajo PM2 detrás de nginx (mismo patrón que el server/ de Tradexpar),
#         expuesto en un subdominio HTTPS dedicado. Ver docs/deploy-fastrax-backend.md.
FASTRAX_BACKEND_PORT=8787
# Host de escucha. En la VPS dejar 127.0.0.1 (solo nginx lo alcanza). 0.0.0.0 solo si no hay proxy.
FASTRAX_BACKEND_HOST=127.0.0.1
# Orígenes permitidos (CORS). En prod: el dominio público del frontend (Hostinger), sin barra final.
# Ej.: FASTRAX_BACKEND_CORS_ORIGINS=https://tu-tienda.com,https://www.tu-tienda.com
FASTRAX_BACKEND_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# URL del mini-backend vista desde el navegador (frontend Vite). DEBE ser HTTPS en prod
# (un sitio HTTPS no puede llamar a http://). Ej. prod: https://enertech-api.neura.com.py
# En local: http://localhost:8787
VITE_FASTRAX_BACKEND_URL=http://localhost:8787
